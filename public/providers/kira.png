<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kira AI - API Chat AI by Huy Kira</title>
  <meta name="description"
    content="Trải nghiệm chatbot AI đỉnh cao, quản lý khóa API và xây dựng hệ thống API Proxy thông minh với nền tảng Kira AI.">

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="shortcut icon" type="image/png" href="/favicon.png">

  <!-- Google Fonts: Inter & Outfit -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap"
    rel="stylesheet">

  <!-- FontAwesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <!-- Core Stylesheet -->
  <link rel="stylesheet" href="/css/style.css?v=1.1">
</head>

<body>

  <!-- Toast Notification Container -->
  <div id="toast-container" class="toast-container"></div>

  <!-- Global Confirmation Modal -->
  <div id="confirm-modal" class="modal-overlay" style="display: none;">
    <div class="modal-card confirm-card">
      <h3 id="confirm-title" class="modal-title">Xác nhận</h3>
      <p id="confirm-message" class="modal-body">Bạn có chắc chắn muốn thực hiện hành động này?</p>
      <div class="modal-footer">
        <button id="confirm-cancel-btn" class="btn btn-secondary">Hủy</button>
        <button id="confirm-ok-btn" class="btn btn-danger">Xác nhận</button>
      </div>
    </div>
  </div>

  <!-- API Key Generation Result Modal -->
  <div id="key-modal" class="modal-overlay" style="display: none;">
    <div class="modal-card key-card animate-zoom">
      <div class="modal-header">
        <h3 class="modal-title"><i class="fa-solid fa-key text-gradient"></i> Đã tạo API Key thành công</h3>
        <button class="close-modal-btn" onclick="closeKeyModal()">&times;</button>
      </div>
      <p class="modal-body text-secondary">Vui lòng sao chép khóa API bên dưới. Bạn sẽ <strong>không thể xem
          lại</strong> khóa này sau khi đóng hộp thoại này vì lý do bảo mật.</p>

      <div class="key-display-wrapper">
        <input type="text" id="new-key-value" class="input-field key-input-display" readonly>
        <button onclick="copyNewKey()" class="btn btn-primary btn-copy-modal" id="copy-modal-btn">
          <i class="fa-regular fa-copy"></i> Sao chép
        </button>
      </div>

      <div class="modal-footer">
        <button onclick="closeKeyModal()" class="btn btn-secondary w-full">Tôi đã lưu khóa, đóng hộp thoại</button>
      </div>
    </div>
  </div>

  <!-- MAIN APPLICATION CONTAINER -->
  <div id="app" class="app-container">

    <!-- 1. Giao diện Trang chủ (Homepage Layout) -->
    <div id="home-screen" class="home-screen" style="display: flex;">
      <!-- Sticky Navigation Header -->
      <header class="home-header">
        <div class="home-header-container">
          <div class="logo">
            <img src="/images/logo.png" class="logo-img" alt="Kira AI">
            <span class="logo-text">Kira AI</span>
          </div>

          <nav class="home-nav">
            <!-- Dynamic Login/Dashboard buttons -->
            <div id="home-auth-nav" class="home-auth-actions"></div>
          </nav>
        </div>
      </header>

      <!-- Floating TubeLight Navbar (Centered inside viewport on desktop, floats at bottom on mobile) -->
      <div class="tubelight-navbar">
        <div class="tubelight-navbar-inner">
          <a href="#tinh-nang" class="tubelight-nav-item active">
            <span class="nav-text">Tính năng</span>
            <span class="nav-icon"><i class="fa-solid fa-wand-magic-sparkles"></i></span>
          </a>
          <a href="#mobile-app" class="tubelight-nav-item">
            <span class="nav-text">Tải App</span>
            <span class="nav-icon"><i class="fa-solid fa-mobile-screen-button"></i></span>
          </a>
          <a href="#bang-gia" class="tubelight-nav-item">
            <span class="nav-text">Bảng giá API</span>
            <span class="nav-icon"><i class="fa-solid fa-credit-card"></i></span>
          </a>
          <a href="#testimonials" class="tubelight-nav-item">
            <span class="nav-text">Khách hàng</span>
            <span class="nav-icon"><i class="fa-solid fa-comments"></i></span>
          </a>
          <a href="#tin-tuc" class="tubelight-nav-item">
            <span class="nav-text">Tin tức</span>
            <span class="nav-icon"><i class="fa-solid fa-newspaper"></i></span>
          </a>
          <a href="/documents" target="_blank" class="tubelight-nav-item">
            <span class="nav-text">Tài liệu API</span>
            <span class="nav-icon"><i class="fa-solid fa-book"></i></span>
          </a>

          <!-- Active Lamp Indicator -->
          <div class="tubelight-lamp">
            <div class="tubelight-lamp-light">
              <div class="lamp-glow-1"></div>
              <div class="lamp-glow-2"></div>
              <div class="lamp-glow-3"></div>
            </div>
          </div>
        </div>
    </div>

    <!-- Wrapper for home page main content sections -->
    <div id="homepage-sections-content">
      <!-- Hero Section Outer Wrapper -->
      <div class="hero-section-outer">
        <!-- Hero Section -->
        <section class="hero-section">
          <div class="hero-bg-glow"></div>

          <!-- Left Side: Text Content -->
          <div class="hero-content-left">
            <span class="badge-new animate-pulse"><i class="fa-solid fa-rocket"></i> Mới: Hỗ trợ Kira 2.5 & 3.1
              TTS</span>
            <h1 class="hero-title">Kira AI Platform</h1>
            <p class="hero-subtitle">Cung cấp các API AI tiên tiến, hỗ trợ Chat AI thế hệ mới, Tạo hình ảnh Kira Image,
              Tạo
              video Kira Video và Tổng hợp giọng nói tự nhiên với tốc độ cao.</p>
            <div class="hero-actions">
              <div class="btn-container-with-badge">
                <span class="btn-badge-free">Free</span>
                <button class="btn-premium-trial" onclick="onHeroStartClick()">
                  Nhận 50k tokens
                </button>
              </div>

              <button class="btn-premium-docs" onclick="window.location.href='/documents'">
                <i class="fa-solid fa-book"></i> Tài liệu
              </button>
            </div>
          </div>

          <!-- Right Side: Image Accordion -->
          <div class="hero-accordion-right">
            <div class="hero-accordion-container">
              <!-- Item 1: Voice Assistant -->
              <div class="accordion-item" data-index="0">
                <img src="/images/kira_mobile_voice.png" alt="Voice Assistant"
                  onerror="this.onerror=null; this.src='https://placehold.co/400x450/2d3748/ffffff?text=Voice+Assistant';">
                <div class="accordion-overlay"></div>
                <span class="accordion-title">Voice Assistant</span>
              </div>
              <!-- Item 2: AI Image Generation -->
              <div class="accordion-item" data-index="1">
                <img src="/images/kira_mobile_gallery.png" alt="AI Image Generation"
                  onerror="this.onerror=null; this.src='https://placehold.co/400x450/2d3748/ffffff?text=Image+Generation';">
                <div class="accordion-overlay"></div>
                <span class="accordion-title">AI Image Generation</span>
              </div>
              <!-- Item 3: AI Chatbot + Local RAG -->
              <div class="accordion-item" data-index="2">
                <img src="/images/kira_mobile_app.png" alt="AI Chatbot + Local RAG"
                  onerror="this.onerror=null; this.src='https://placehold.co/400x450/2d3748/ffffff?text=AI+Chatbot';">
                <div class="accordion-overlay"></div>
                <span class="accordion-title">AI Chatbot + RAG</span>
              </div>
              <!-- Item 4: AI Agent -->
              <div class="accordion-item" data-index="3">
                <img src="/images/kira_mobile_video.png" alt="AI Agent"
                  onerror="this.onerror=null; this.src='https://placehold.co/400x450/2d3748/ffffff?text=AI+Agent';">
                <div class="accordion-overlay"></div>
                <span class="accordion-title">AI Agent</span>
              </div>
              <!-- Item 5: Kira Mobile App (Active index 4 by default) -->
              <div class="accordion-item active" data-index="4">
                <img src="/images/kira_mobile_hero.png" alt="Kira Mobile App"
                  onerror="this.onerror=null; this.src='https://placehold.co/400x450/2d3748/ffffff?text=Kira+Mobile+App';">
                <div class="accordion-overlay"></div>
                <span class="accordion-title">Kira Mobile App</span>
              </div>
            </div>
          </div>
        </section>
      </div>

      <!-- Core Features Grid -->
      <div class="features-section-outer">
        <div class="features-bg-grid"></div>
        <div class="features-glow-light"></div>

        <section id="tinh-nang" class="features-section">
          <div class="section-title">
            <span class="tech-badge"><i class="fa-solid fa-microchip"></i> KIRA COGNITIVE SYSTEM</span>
            <h2>Dịch vụ của <span class="text-gradient">Kira AI</span></h2>
            <p>Tích hợp nhanh chóng, lập trình dễ dàng qua chuẩn kết nối API tương thích SDK OpenAI và với mọi ngôn ngữ
              lập trình.</p>
          </div>

          <div class="features-grid">
            <!-- Card 1: Chat AI -->
            <div class="feature-card tech-card" style="--card-theme: var(--primary);">
              <div class="card-glow-effect"></div>
              <div class="card-decor-corners">
                <span class="corner tl"></span>
                <span class="corner tr"></span>
                <span class="corner bl"></span>
                <span class="corner br"></span>
              </div>

              <div class="card-header-row">
                <div class="feature-icon-wrapper">
                  <div class="feature-icon">
                    <i class="fa-solid fa-comment-dots"></i>
                  </div>
                  <div class="icon-glow"></div>
                </div>

                <div class="card-header-meta">
                  <span class="tech-metric"><i class="fa-solid fa-gauge-high"></i> ~150ms</span>
                </div>
              </div>

              <h3>Chat AI</h3>
              <p>Trò chuyện thông minh, phân tích mã nguồn và xử lý dữ liệu lập trình mượt mà với Kira 3.5/2.5.</p>

              <ul class="tech-specs-list">
                <li><i class="fa-solid fa-microchip"></i> Models: Kira 3.5 Flash & 2.5 Pro</li>
                <li><i class="fa-solid fa-envelope-open-text"></i> Context: 1.0M Tokens Window</li>
                <li><i class="fa-solid fa-terminal"></i> Hỗ trợ: Code assistant & RAG</li>
              </ul>
            </div>

            <!-- Card 2: Tạo Hình Ảnh -->
            <div class="feature-card tech-card" style="--card-theme: 280 75% 60%;">
              <div class="card-glow-effect"></div>
              <div class="card-decor-corners">
                <span class="corner tl"></span>
                <span class="corner tr"></span>
                <span class="corner bl"></span>
                <span class="corner br"></span>
              </div>

              <div class="card-header-row">
                <div class="feature-icon-wrapper">
                  <div class="feature-icon">
                    <i class="fa-solid fa-image"></i>
                  </div>
                  <div class="icon-glow"></div>
                </div>

                <div class="card-header-meta">
                  <span class="tech-metric"><i class="fa-solid fa-vector-square"></i> ULTRA-HD</span>
                </div>
              </div>

              <h3>Tạo Hình Ảnh</h3>
              <p>Chuyển đổi ý tưởng dạng văn bản thành hình ảnh chi tiết và sắc nét theo đúng tỉ lệ yêu cầu.</p>

              <ul class="tech-specs-list">
                <li><i class="fa-solid fa-wand-magic-sparkles"></i> Engine: Kira Image 3.1 & 3 Pro</li>
                <li><i class="fa-solid fa-crop-simple"></i> Tỷ lệ: 16:9, 9:16, 1:1, 4:3</li>
                <li><i class="fa-solid fa-copy"></i> Hỗ trợ: Image-to-Image ref</li>
              </ul>
            </div>

            <!-- Card 3: Tạo Video -->
            <div class="feature-card tech-card" style="--card-theme: 150 75% 45%;">
              <div class="card-glow-effect"></div>
              <div class="card-decor-corners">
                <span class="corner tl"></span>
                <span class="corner tr"></span>
                <span class="corner bl"></span>
                <span class="corner br"></span>
              </div>

              <div class="card-header-row">
                <div class="feature-icon-wrapper">
                  <div class="feature-icon">
                    <i class="fa-solid fa-video"></i>
                  </div>
                  <div class="icon-glow"></div>
                </div>

                <div class="card-header-meta">
                  <span class="tech-metric"><i class="fa-solid fa-film"></i> 60 FPS</span>
                </div>
              </div>

              <h3>Tạo Video</h3>
              <p>Sáng tạo các đoạn chuyển động video độc đáo, chất lượng từ prompts mô tả.</p>

              <ul class="tech-specs-list">
                <li><i class="fa-solid fa-video"></i> Engine: Kira Video 3.1 Generate</li>
                <li><i class="fa-solid fa-clock"></i> Thời lượng: 4s - 8s per render</li>
                <li><i class="fa-solid fa-camera"></i> Camera controls: Zoom/Pan/Orbit</li>
              </ul>
            </div>

            <!-- Card 4: Tạo Giọng Nói -->
            <div class="feature-card tech-card" style="--card-theme: 35 85% 55%;">
              <div class="card-glow-effect"></div>
              <div class="card-decor-corners">
                <span class="corner tl"></span>
                <span class="corner tr"></span>
                <span class="corner bl"></span>
                <span class="corner br"></span>
              </div>

              <div class="card-header-row">
                <div class="feature-icon-wrapper">
                  <div class="feature-icon">
                    <i class="fa-solid fa-microphone-lines"></i>
                  </div>
                  <div class="icon-glow"></div>
                </div>

                <div class="card-header-meta">
                  <span class="tech-metric"><i class="fa-solid fa-headphones"></i> HI-FI</span>
                </div>
              </div>

              <h3>Tạo Giọng Nói (TTS)</h3>
              <p>Tổng hợp giọng đọc tự nhiên đa dạng biểu cảm với kho 30 giọng đọc Kira chất lượng cao.</p>

              <ul class="tech-specs-list">
                <li><i class="fa-solid fa-volume-high"></i> Engine: Kira Voices 3.1 & 2.5</li>
                <li><i class="fa-solid fa-globe"></i> Kho giọng: 30+ giọng nói Việt/Anh</li>
                <li><i class="fa-solid fa-sliders"></i> Tính năng: Custom speed & pitch</li>
              </ul>
            </div>
          </div>

          <!-- Interactive AI Models List -->
          <div class="models-showcase-container">
            <ul class="models-grid animate-slide-up" id="models-list-container">
              <!-- Dynamically populated via JS -->
            </ul>
          </div>
        </section>
      </div>

      <!-- Mobile App Showcase Section -->
      <section id="mobile-app" class="mobile-app-section">
        <div class="mobile-app-container">
          <!-- Left side: smartphone mockup visual as 3D circular gallery -->
          <div class="mobile-app-visual circular-gallery-visual animate-slide-up">
            <div class="circular-gallery-wrapper">
              <div class="circular-gallery-inner" id="app-circular-gallery">
                <!-- Item 1: Chat AI -->
                <div class="circular-item" style="--item-angle: 0deg;">
                  <div class="circular-item-card">
                    <img src="/images/kira_mobile_app.png" alt="Kira AI Chat App">
                    <div class="circular-item-overlay">
                      <h4>Trò chuyện Chat AI</h4>
                      <p>Trực quan, mượt mà trên di động</p>
                    </div>
                  </div>
                </div>
                <!-- Item 2: Voice Chat -->
                <div class="circular-item" style="--item-angle: 45deg;">
                  <div class="circular-item-card">
                    <img src="/images/kira_mobile_voice.png" alt="Kira Voice Assistant">
                    <div class="circular-item-overlay">
                      <h4>Trợ lý Giọng nói</h4>
                      <p>Đàm thoại tự nhiên thế hệ mới</p>
                    </div>
                  </div>
                </div>
                <!-- Item 3: Image Gallery -->
                <div class="circular-item" style="--item-angle: 90deg;">
                  <div class="circular-item-card">
                    <img src="/images/kira_mobile_gallery.png" alt="Kira AI Art Gallery">
                    <div class="circular-item-overlay">
                      <h4>Thư viện Tạo ảnh</h4>
                      <p>Mỹ thuật số trong lòng bàn tay</p>
                    </div>
                  </div>
                </div>
                <!-- Item 4: Video Generator -->
                <div class="circular-item" style="--item-angle: 135deg;">
                  <div class="circular-item-card">
                    <img src="/images/kira_mobile_video.png" alt="Kira AI Video Generator">
                    <div class="circular-item-overlay">
                      <h4>Sáng tạo Video Clip</h4>
                      <p>Dựng phim với prompt di động</p>
                    </div>
                  </div>
                </div>
                <!-- Item 5: Chat AI (duped) -->
                <div class="circular-item" style="--item-angle: 180deg;">
                  <div class="circular-item-card">
                    <img src="/images/kira_mobile_app.png" alt="Kira AI Chat App">
                    <div class="circular-item-overlay">
                      <h4>Trò chuyện Chat AI</h4>
                      <p>Trực quan, mượt mà trên di động</p>
                    </div>
                  </div>
                </div>
                <!-- Item 6: Voice Chat (duped) -->
                <div class="circular-item" style="--item-angle: 225deg;">
                  <div class="circular-item-card">
                    <img src="/images/kira_mobile_voice.png" alt="Kira Voice Assistant">
                    <div class="circular-item-overlay">
                      <h4>Trợ lý Giọng nói</h4>
                      <p>Đàm thoại tự nhiên thế hệ mới</p>
                    </div>
                  </div>
                </div>
                <!-- Item 7: Image Gallery (duped) -->
                <div class="circular-item" style="--item-angle: 270deg;">
                  <div class="circular-item-card">
                    <img src="/images/kira_mobile_gallery.png" alt="Kira AI Art Gallery">
                    <div class="circular-item-overlay">
                      <h4>Thư viện Tạo ảnh</h4>
                      <p>Mỹ thuật số trong lòng bàn tay</p>
                    </div>
                  </div>
                </div>
                <!-- Item 8: Video Generator (duped) -->
                <div class="circular-item" style="--item-angle: 315deg;">
                  <div class="circular-item-card">
                    <img src="/images/kira_mobile_video.png" alt="Kira AI Video Generator">
                    <div class="circular-item-overlay">
                      <h4>Sáng tạo Video Clip</h4>
                      <p>Dựng phim với prompt di động</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Right side: details and text -->
          <div class="mobile-app-content">
            <div class="section-title-left">
              <span class="badge-accent"><i class="fa-solid fa-mobile-screen-button"></i> Ứng dụng di động</span>
              <h2>Trải nghiệm Kira AI App</h2>
              <p class="subtitle">Mang sức mạnh trí tuệ nhân tạo đi khắp mọi nơi. Trải nghiệm tốc độ xử lý nhanh chóng,
                tương tác giọng nói tức thì ngay trên thiết bị di động của bạn.</p>
            </div>

            <ul class="mobile-features">
              <li>
                <div class="m-feat-icon"><i class="fa-solid fa-arrows-rotate"></i></div>
                <div class="m-feat-text">
                  <h4>Đồng bộ hóa đám mây tức thời</h4>
                  <p>Mọi cuộc hội thoại, lịch sử chat và các cài đặt cá nhân hóa đều được đồng bộ tự động giữa các phiên
                    bản web và di động theo thời gian thực.</p>
                </div>
              </li>
              <li>
                <div class="m-feat-icon"><i class="fa-solid fa-microphone"></i></div>
                <div class="m-feat-text">
                  <h4>Trò chuyện giọng nói rảnh tay</h4>
                  <p>Tận dụng công nghệ Kira TTS (Text-to-Speech) và Speech-to-Text thế hệ mới để trò chuyện trực tiếp
                    bằng giọng nói tự nhiên, mượt mà giống như đang gọi điện thoại.</p>
                </div>
              </li>
            </ul>

            <div class="download-actions">
              <a href="#"
                onclick="event.preventDefault(); showToast('Phiên bản App Store cho iOS đang được duyệt!', 'info')"
                class="btn-download download-appstore">
                <i class="fa-brands fa-apple"></i>
                <div class="download-text">
                  <span>Tải về trên</span>
                  <strong>App Store</strong>
                </div>
              </a>
              <a href="#"
                onclick="event.preventDefault(); showToast('Phiên bản Google Play cho Android đang được duyệt!', 'info')"
                class="btn-download download-googleplay">
                <i class="fa-brands fa-google-play"></i>
                <div class="download-text">
                  <span>Tải về trên</span>
                  <strong>Google Play</strong>
                </div>
              </a>
            </div>
          </div>
        </div>

        <!-- Stats & Author Dashboard Wrapper -->
        <div class="mobile-app-dashboard-wrapper">
          <!-- Stats Dashboard Block -->
          <div class="mobile-app-stats">
            <div class="stat-item">
              <div class="stat-num">4.8 ★</div>
              <div class="stat-label">Đánh giá Store</div>
            </div>
            <div class="stat-item-divider"></div>
            <div class="stat-item">
              <div class="stat-num">100K+</div>
              <div class="stat-label">Lượt tải về</div>
            </div>
            <div class="stat-item-divider"></div>
            <div class="stat-item">
              <div class="stat-num">99.9%</div>
              <div class="stat-label">Uptime hệ thống</div>
            </div>
          </div>

          <!-- Author Profile Card -->
          <a href="https://huykira.net" target="_blank" class="mobile-app-author-card">
            <img src="/images/huykira.webp" alt="Huy Kira" class="author-avatar">
            <div class="author-info">
              <div class="author-name">Huy Kira</div>
              <div class="author-title">Full Stack Developer</div>
              <div class="author-exp">12 years of experience</div>
            </div>
          </a>
        </div>
      </section>

      <!-- API Pricing Grid -->
      <div class="pricing-section-outer">
        <canvas id="pricing-starfield" class="pricing-starfield"></canvas>
