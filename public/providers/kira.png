        <!-- Text hover effect -->
        <div class="footer-text-hover-container">
          <svg id="footer-text-hover-svg" viewBox="0 0 300 100" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="textGradient" gradientUnits="userSpaceOnUse" cx="50%" cy="50%" r="25%">
                <stop offset="0%" stop-color="#eab308" />
                <stop offset="25%" stop-color="#ef4444" />
                <stop offset="50%" stop-color="#80eeb4" />
                <stop offset="75%" stop-color="#06b6d4" />
                <stop offset="100%" stop-color="#8b5cf6" />
              </linearGradient>

              <radialGradient id="revealMask" gradientUnits="userSpaceOnUse" r="20%" cx="50%" cy="50%">
                <stop offset="0%" stop-color="white" />
                <stop offset="100%" stop-color="black" />
              </radialGradient>

              <mask id="textMask">
                <rect x="0" y="0" width="100%" height="100%" fill="url(#revealMask)" />
              </mask>
            </defs>

            <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" stroke-width="0.3"
              class="text-stroke-bg">
              KIRA AI
            </text>

            <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" stroke-width="0.3"
              class="text-stroke-glow">
              KIRA AI
            </text>

            <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle" stroke="url(#textGradient)"
              stroke-width="0.3" mask="url(#textMask)" class="text-stroke-gradient">
              KIRA AI
            </text>
          </svg>
        </div>
      </footer>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const svg = document.getElementById('footer-text-hover-svg');
          const mask = document.getElementById('revealMask');
          if (svg && mask) {
            svg.addEventListener('mousemove', (e) => {
              const rect = svg.getBoundingClientRect();
              const x = ((e.clientX - rect.left) / rect.width) * 100;
              const y = ((e.clientY - rect.top) / rect.height) * 100;
              mask.setAttribute('cx', `${x}%`);
              mask.setAttribute('cy', `${y}%`);
            });

            svg.addEventListener('mouseenter', () => {
              svg.classList.add('hovered');
            });

            svg.addEventListener('mouseleave', () => {
              svg.classList.remove('hovered');
              mask.setAttribute('cx', '50%');
              mask.setAttribute('cy', '50%');
            });
          }
        });
      </script>
    </div>
  </div>

    <!-- 1.1 Popup Modal Đăng nhập / Đăng ký (Auth Modal Popup) -->
    <div id="auth-modal" class="modal-overlay" style="display: none;">
      <div class="auth-modal-card animate-scale-up">
        <button class="close-auth-modal" onclick="closeAuthModal()">&times;</button>

        <!-- Modal Tabs -->
        <div class="auth-modal-tabs">
          <button id="tab-btn-login" class="auth-tab-btn active" onclick="switchAuthTab('login')">Đăng nhập</button>
          <button id="tab-btn-register" class="auth-tab-btn" onclick="switchAuthTab('register')">Đăng ký</button>
        </div>

        <!-- Login Form Content -->
        <div id="auth-login-section" class="auth-tab-content">
          <div class="auth-modal-body">
            <div class="auth-avatar-circle">
              <i class="fa-solid fa-user"></i>
            </div>
            <h3>Chào mừng trở lại!</h3>
            <p class="auth-subtitle">Đăng nhập để kết nối với Kira AI và phát triển</p>

            <div id="google-login-btn" style="display: flex; justify-content: center; width: 100%; margin-bottom: 15px;"></div>

            <div class="auth-divider"><span>Hoặc sử dụng tài khoản</span></div>

            <form id="login-form" onsubmit="handleLogin(event)">
              <div class="form-group">
                <label for="login-username"><i class="fa-regular fa-envelope"></i> Email hoặc Tên đăng nhập</label>
                <input type="text" id="login-username" class="input-field" placeholder="Tên đăng nhập hoặc email..."
                  required>
              </div>
              <div class="form-group">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                  <label for="login-password"><i class="fa-solid fa-lock"></i> Mật khẩu</label>
                  <a href="#" class="auth-link-forgot"
                    onclick="event.preventDefault(); switchAuthTab('forgot')">Quên
                    mật khẩu?</a>
                </div>
                <div style="position: relative; width: 100%;">
                  <input type="password" id="login-password" class="input-field" placeholder="••••••••" required>
                  <i class="fa-regular fa-eye-slash toggle-password-btn"
                    onclick="togglePasswordVisibility('login-password', this)"></i>
                </div>
              </div>
              <button type="submit" class="btn btn-primary btn-auth-submit" id="login-submit-btn">
                Đăng nhập <i class="fa-solid fa-arrow-right-long"></i>
              </button>
            </form>
            <div class="auth-footer-prompt">
              Chưa có tài khoản? <a href="#" onclick="event.preventDefault(); switchAuthTab('register')">Đăng ký miễn
                phí</a>
            </div>
          </div>
        </div>

        <!-- Forgot Password Form Content -->
        <div id="auth-forgot-section" class="auth-tab-content" style="display: none;">
          <div class="auth-modal-body">
            <div class="auth-avatar-circle" style="background: rgba(200,121,65,0.1); color: hsl(var(--primary));">
              <i class="fa-solid fa-key"></i>
            </div>
            <h3>Khôi phục mật khẩu</h3>
            <p class="auth-subtitle">Nhập email để nhận mã OTP xác thực đặt lại mật khẩu</p>

            <!-- Forgot step 1: Request OTP -->
            <form id="forgot-password-form" onsubmit="handleForgotPassword(event)">
              <div class="form-group">
                <label for="forgot-email"><i class="fa-regular fa-envelope"></i> Địa chỉ Email</label>
                <input type="email" id="forgot-email" class="input-field" placeholder="Nhập email tài khoản của bạn..." required>
              </div>
              <button type="submit" class="btn btn-primary btn-auth-submit" id="forgot-submit-btn">
                Gửi mã xác nhận OTP <i class="fa-solid fa-paper-plane"></i>
              </button>
            </form>

            <!-- Forgot step 2: Reset Password (hidden by default) -->
            <form id="reset-password-form" onsubmit="handleResetPassword(event)" style="display: none;">
              <div class="form-group">
                <label for="reset-code"><i class="fa-solid fa-shield-halved"></i> Mã xác nhận OTP</label>
                <input type="text" id="reset-code" class="input-field" placeholder="Nhập mã OTP 6 chữ số..." required>
              </div>
              <div class="form-group">
                <label for="reset-new-password"><i class="fa-solid fa-lock"></i> Mật khẩu mới</label>
                <div style="position: relative; width: 100%;">
                  <input type="password" id="reset-new-password" class="input-field" placeholder="Tối thiểu 6 ký tự..." required>
                  <i class="fa-regular fa-eye-slash toggle-password-btn" onclick="togglePasswordVisibility('reset-new-password', this)"></i>
                </div>
              </div>
              <button type="submit" class="btn btn-primary btn-auth-submit" id="reset-submit-btn">
                Xác nhận đổi mật khẩu <i class="fa-solid fa-check"></i>
              </button>
            </form>

            <div class="auth-footer-prompt">
              Quay lại <a href="#" onclick="event.preventDefault(); switchAuthTab('login')">Đăng nhập</a>
            </div>
          </div>
        </div>

        <!-- Register Form Content -->
        <div id="auth-register-section" class="auth-tab-content" style="display: none;">
          <div class="auth-modal-body">
            <div class="auth-avatar-circle">
              <i class="fa-solid fa-user-plus"></i>
            </div>
            <h3>Đăng ký thành viên</h3>
            <p class="auth-subtitle">Trở thành thành viên và trải nghiệm sức mạnh AI</p>

            <div id="google-register-btn" style="display: flex; justify-content: center; width: 100%; margin-bottom: 15px;"></div>

            <div class="auth-divider"><span>Hoặc điền thông tin</span></div>

            <form id="register-form" onsubmit="handleRegister(event)">
              <div class="form-group">
                <label for="reg-username"><i class="fa-regular fa-user"></i> Tên đăng nhập</label>
                <input type="text" id="reg-username" class="input-field" placeholder="Nhập tên đăng nhập viết liền..."
                  required autocomplete="username">
              </div>
              <div class="form-group">
                <label for="reg-email"><i class="fa-regular fa-envelope"></i> Email của bạn</label>
                <input type="email" id="reg-email" class="input-field" placeholder="email@vi-du.com" required
                  autocomplete="email">
              </div>
              <div class="form-group">
                <label for="reg-password"><i class="fa-solid fa-lock"></i> Mật khẩu</label>
                <div style="position: relative; width: 100%;">
                  <input type="password" id="reg-password" class="input-field" placeholder="Tối thiểu 6 ký tự..."
                    required autocomplete="new-password">
                  <i class="fa-regular fa-eye-slash toggle-password-btn"
                    onclick="togglePasswordVisibility('reg-password', this)"></i>
                </div>
              </div>
              <div class="form-group">
                <label for="reg-confirm-password"><i class="fa-solid fa-lock"></i> Xác nhận mật khẩu</label>
                <div style="position: relative; width: 100%;">
                  <input type="password" id="reg-confirm-password" class="input-field"
                    placeholder="Nhập lại mật khẩu..." required autocomplete="new-password">
                  <i class="fa-regular fa-eye-slash toggle-password-btn"
                    onclick="togglePasswordVisibility('reg-confirm-password', this)"></i>
                </div>
              </div>
              <button type="submit" class="btn btn-primary btn-auth-submit" id="register-submit-btn">
                Tạo tài khoản <i class="fa-solid fa-arrow-right-long"></i>
              </button>
            </form>
            <div class="auth-footer-prompt">
              Đã có tài khoản? <a href="#" onclick="event.preventDefault(); switchAuthTab('login')">Đăng nhập ngay</a>
            </div>
          </div>
        </div>

        <!-- OTP Verify Form Content -->
        <div id="auth-verify-section" class="auth-tab-content" style="display: none;">
          <div class="auth-modal-body">
            <div class="auth-avatar-circle" style="background: linear-gradient(135deg, #e0d5cb, #8c6239);">
              <i class="fa-solid fa-envelope-circle-check"></i>
            </div>
            <h3>Xác minh Email</h3>
            <p class="auth-subtitle">Một mã OTP đã được gửi tới địa chỉ email của bạn. Vui lòng nhập mã để hoàn tất đăng ký.</p>

            <form id="verify-form" onsubmit="handleVerifyOTP(event)">
              <div class="form-group">
                <label for="verify-email"><i class="fa-regular fa-envelope"></i> Email của bạn</label>
                <input type="email" id="verify-email" class="input-field" readonly style="background-color: rgba(0,0,0,0.05); color: #888;">
              </div>
              <div class="form-group">
                <label for="verify-otp"><i class="fa-solid fa-key"></i> Nhập mã OTP (6 số)</label>
                <input type="text" id="verify-otp" class="input-field" placeholder="Mã OTP gồm 6 chữ số..." required maxlength="6" pattern="\d{6}">
              </div>
              <button type="submit" class="btn btn-primary btn-auth-submit" id="verify-submit-btn">
                Xác nhận & Đăng ký <i class="fa-solid fa-arrow-right-long"></i>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- 1.2 Popup Modal Chi Tiết Model (AI Model Details Modal) -->
    <div id="model-details-modal" class="modal-overlay" style="display: none;">
      <div class="model-details-modal-card animate-scale-up">
        <button class="close-auth-modal" onclick="closeModelDetailsModal()">&times;</button>
        <h3 id="modal-model-name" class="modal-title"
          style="margin-bottom: 0.5rem; text-align: left; font-size: 1.5rem; font-weight: 700; color: hsl(var(--text-primary)); border: none; padding: 0;">
          Model Name</h3>
        <p id="modal-model-desc"
          style="font-size: 0.9rem; color: hsl(var(--text-secondary)); margin-bottom: 1.5rem; line-height: 1.6; text-align: left;">
          Model Description</p>

        <div class="model-details-grid">
          <div class="model-details-item">
            <div class="model-details-label">Nhà cung cấp</div>
            <div id="modal-model-provider" class="model-details-value">Provider</div>
          </div>
          <div class="model-details-item">
            <div class="model-details-label">Dòng mô hình</div>
            <div id="modal-model-family" class="model-details-value">Family</div>
          </div>
          <div class="model-details-item">
            <div class="model-details-label">Token Ngữ Cảnh</div>
            <div id="modal-model-context" class="model-details-value">Context</div>
          </div>
          <div class="model-details-item">
            <div class="model-details-label">Định dạng đầu ra</div>
            <div id="modal-model-formats" class="model-details-value">Formats</div>
          </div>
        </div>

        <div id="modal-model-meta-container" class="model-details-meta-container" style="display: none;">
          <h4 class="model-details-meta-title">Thông tin bổ sung</h4>
          <div id="modal-model-meta">
            <!-- Render metadata dynamically -->
          </div>
        </div>
      </div>
    </div>

    <!-- 2. Giao diện chính (Dashboard Layout) -->
    <div id="dashboard-screen" class="dashboard-screen" style="display: none;">

      <!-- Mobile Sidebar Backdrop Overlay -->
      <div class="sidebar-overlay" onclick="toggleSidebar()"></div>

      <!-- Mobile Dashboard Header -->
      <header class="mobile-dashboard-header">
        <button class="menu-toggle-btn" onclick="toggleSidebar()" title="Mở danh mục">
          <i class="fa-solid fa-bars"></i>
        </button>
        <div class="mobile-dashboard-logo">
          <img src="/images/logo.png" class="logo-img" alt="Kira AI">
          <span class="logo-title text-gradient">Kira AI</span>
        </div>
        <div class="mobile-dashboard-actions">
          <a href="/" class="logo-home-link" onclick="event.preventDefault(); navigateToHome();" title="Về trang chủ">
            <i class="fa-solid fa-house"></i>
          </a>
          <div class="mobile-dashboard-user" onclick="switchTab('guide')" title="Hướng dẫn sử dụng">
            <i class="fa-solid fa-user-astronaut"></i>
          </div>
        </div>
      </header>

      <!-- Sidebar Navigation -->
      <aside class="sidebar">
        <div class="sidebar-header">
          <div class="sidebar-logo">
            <img src="/images/logo.png" class="logo-img" alt="Kira AI">
            <span class="logo-title text-gradient">Kira AI</span>
          </div>
          <div class="sidebar-header-actions">
            <a href="/" class="logo-home-link" onclick="event.preventDefault(); navigateToHome();" title="Về trang chủ">
              <i class="fa-solid fa-house"></i>
            </a>
            <button class="close-sidebar-btn" onclick="toggleSidebar()" title="Đóng danh mục">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>
        </div>

        <div class="user-profile-badge" onclick="switchTab('profile')" style="cursor: pointer;" title="Cài đặt tài khoản">
          <div class="user-avatar" id="user-avatar-container"><i class="fa-solid fa-user-astronaut"></i></div>
          <div class="user-details">
            <div class="username-display" id="user-display-name">Username</div>
            <div style="display: flex; align-items: center; gap: 6px; margin: 2px 0;">
              <span id="user-id-display"
                style="font-size: 0.75rem; color: hsl(var(--text-muted)); font-family: monospace;"></span>
              <button onclick="copyUserId()"
                style="background: none; border: none; color: hsl(var(--text-muted)); cursor: pointer; font-size: 0.7rem; padding: 2px; display: inline-flex; align-items: center;"
                title="Copy User ID">
                <i class="fa-regular fa-copy"></i>
              </button>
            </div>
            <div class="user-role-pill" id="user-role-pill">USER</div>
          </div>
        </div>

        <!-- Token Limit Status Box -->
        <div class="sidebar-token-status" id="sidebar-token-status"
          style="margin: 0.5rem 1.25rem 1.25rem 1.25rem; padding: 0.75rem; background: hsl(var(--bg-card-hover)); border: 1px solid hsl(var(--border)); border-radius: 8px; font-size: 0.85rem; display: flex; flex-direction: column; gap: 4px;">
          <div
            style="display: flex; align-items: center; justify-content: space-between; font-weight: 500; color: hsl(var(--text-secondary));">
            <span>Hạn mức còn lại:</span>
            <i class="fa-solid fa-chart-pie" style="color: hsl(var(--primary));"></i>
          </div>
          <div id="user-token-limit-display" class="font-semibold text-primary" style="margin-bottom: 2px;">Đang tải...
          </div>
          <div class="token-progress-bar"
            style="width: 100%; height: 6px; background: hsl(var(--border)); border-radius: 3px; overflow: hidden; margin: 2px 0;">
            <div id="user-token-progress-fill"
              style="width: 0%; height: 100%; background: linear-gradient(90deg, hsl(var(--primary)), hsl(var(--accent))); transition: width 0.3s ease;">
            </div>
          </div>
          <div id="user-token-used-display"
            style="font-size: 0.75rem; color: hsl(var(--text-muted)); text-align: right;">Đã dùng hôm nay: 0</div>
        </div>

        <nav class="sidebar-menu">
          <div class="menu-section-label">AI Tools</div>
          <a href="#" class="menu-item active" id="menu-chat" onclick="event.preventDefault(); switchTab('chat')">
            <span class="menu-icon"><i class="fa-regular fa-comments"></i></span> <span>Kira Chatbox</span>
          </a>
          <a href="#" class="menu-item" id="menu-images" onclick="event.preventDefault(); switchTab('images')">
            <span class="menu-icon"><i class="fa-regular fa-image"></i></span> <span>Kira Images</span>
          </a>
          <a href="#" class="menu-item" id="menu-videos" onclick="event.preventDefault(); switchTab('videos')">
            <span class="menu-icon"><i class="fa-solid fa-video"></i></span> <span>Kira Videos</span>
          </a>
          <a href="#" class="menu-item" id="menu-voices" onclick="event.preventDefault(); switchTab('voices')">
            <span class="menu-icon"><i class="fa-solid fa-volume-high"></i></span> <span>Kira Voices</span>
          </a>

          <div class="menu-section-label">Tiện ích</div>
          <a href="#" class="menu-item" id="menu-gallery" onclick="event.preventDefault(); switchTab('gallery')">
            <span class="menu-icon"><i class="fa-solid fa-photo-film"></i></span> <span>Thư viện Media</span>
          </a>
          <a href="/trung-bay" class="menu-item" id="menu-showcase" onclick="event.preventDefault(); window.history.pushState({}, '', '/trung-bay'); routeView();">
            <span class="menu-icon"><i class="fa-solid fa-earth-asia"></i></span> <span>Trưng bày</span>
          </a>
          <a href="#" class="menu-item" id="menu-developer" onclick="event.preventDefault(); switchTab('developer')">
            <span class="menu-icon"><i class="fa-solid fa-code"></i></span> <span>Quản lý API Key</span>
          </a>
          <a href="#" class="menu-item" id="menu-guide" onclick="event.preventDefault(); switchTab('guide')">
            <span class="menu-icon"><i class="fa-regular fa-compass"></i></span> <span>Hướng dẫn sử dụng</span>
          </a>
          <a href="#" class="menu-item" id="menu-admin" style="display: none;"
            onclick="event.preventDefault(); switchTab('admin')">
            <span class="menu-icon"><i class="fa-solid fa-sliders"></i></span> <span>Trang Quản Trị</span>
          </a>
          <a href="#" class="menu-item" id="menu-admin-orders" style="display: none;"
            onclick="event.preventDefault(); switchTab('orders')">
            <span class="menu-icon"><i class="fa-solid fa-cart-shopping"></i></span> <span>Quản lý đơn hàng</span>
          </a>
          <a href="#" class="menu-item" id="menu-my-orders" style="display: none;"
            onclick="event.preventDefault(); switchTab('my-orders')">
            <span class="menu-icon"><i class="fa-solid fa-cart-shopping"></i></span> <span>Đơn hàng của tôi</span>
          </a>
        </nav>

        <div class="sidebar-footer">
          <button onclick="handleLogout()" class="btn btn-logout" id="logout-btn">
            <i class="fa-solid fa-arrow-right-from-bracket"></i> <span>Đăng Xuất</span>
          </button>
        </div>
      </aside>

      <!-- Main Workspace Section -->
      <main class="main-content" id="main-content-view">
      </main>
    </div>
  </div>

  <!-- Detail Showcase Lightbox Modal -->
  <div id="showcase-lightbox" class="modal-overlay" style="display: none;" onclick="closeShowcaseLightbox()">
    <div class="modal-card lightbox-card animate-zoom" style="max-width: 800px; width: 95%; max-height: 90vh; overflow-y: auto; background: hsl(var(--bg-card));" onclick="event.stopPropagation()">
      <div class="modal-header">
        <h3 class="modal-title" id="showcase-lightbox-title"><i class="fa-solid fa-circle-info text-gradient"></i> Chi Tiết Tác Phẩm</h3>
        <button class="close-modal-btn" onclick="closeShowcaseLightbox()">&times;</button>
      </div>
      <div class="modal-body text-center" style="max-height: 60vh; overflow: hidden; display: flex; align-items: center; justify-content: center; background: #000; border-radius: 8px; position: relative;">
        <img id="showcase-lightbox-img" style="max-width: 100%; max-height: 60vh; display: none; object-fit: contain;">
        <video id="showcase-lightbox-video" controls autoplay loop style="max-width: 100%; max-height: 60vh; display: none;"></video>
      </div>
      <div style="padding: 1.25rem; border-top: 1px solid hsl(var(--border)); text-align: left;" id="showcase-lightbox-prompt-container">
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 0.75rem;">
          <img id="showcase-lightbox-avatar" src="/images/default-avatar.jpg" style="width: 36px; height: 36px; border-radius: 50%; border: 1px solid hsl(var(--border)); object-fit: cover;">
          <div>
            <div id="showcase-lightbox-author" style="font-weight: 600; font-size: 0.9rem; color: hsl(var(--text-primary));"></div>
            <div style="font-size: 0.75rem; color: hsl(var(--text-muted));">Tác giả</div>
          </div>
        </div>
        <div style="font-size: 0.75rem; text-transform: uppercase; color: hsl(var(--primary)); font-weight: 700; margin-bottom: 0.5rem; letter-spacing: 0.5px;">Mô tả chi tiết (Prompt)</div>
        <p id="showcase-lightbox-prompt" style="font-weight: 500; font-size: 0.95rem; color: hsl(var(--text-primary)); line-height: 1.5; margin: 0; text-align: left; word-break: break-word;"></p>
        <div id="showcase-lightbox-meta" style="display: flex; flex-wrap: wrap; gap: 12px; margin-top: 0.75rem; font-size: 0.8rem; color: hsl(var(--text-muted)); border-top: 1px dashed hsl(var(--border) / 0.5); padding-top: 0.75rem;"></div>
      </div>
      <div class="modal-footer" style="display: flex; gap: 10px; justify-content: flex-end; padding: 1rem 1.25rem;">
        <button class="btn btn-secondary" onclick="closeShowcaseLightbox()">Đóng</button>
      </div>
    </div>
  </div>

  <!-- Admin Create User Modal -->
  <div id="create-user-modal" class="modal-overlay" style="display: none;">
    <div class="modal-card animate-zoom">
      <div class="modal-header">
        <h3><i class="fa-solid fa-user-plus text-gradient"></i> Tạo Thành Viên Mới</h3>
        <button class="close-modal-btn" onclick="closeCreateUserModal()">&times;</button>
      </div>
      <form id="create-user-form" onsubmit="handleCreateUser(event)">
        <div class="modal-body">
          <p class="text-secondary mb-4">Nhập thông tin tài khoản cho thành viên mới bên dưới.</p>

          <div class="form-group">
            <label for="admin-create-username"><i class="fa-regular fa-user"></i> Tên tài khoản</label>
            <input type="text" id="admin-create-username" class="input-field"
              placeholder="Nhập tên tài khoản (viết liền)..." required autocomplete="off">
          </div>

          <div class="form-group">
            <label for="admin-create-email"><i class="fa-regular fa-envelope"></i> Email liên hệ</label>
            <input type="email" id="admin-create-email" class="input-field" placeholder="name@example.com" required
              autocomplete="off">
          </div>

          <div class="form-group">
            <label for="admin-create-password"><i class="fa-solid fa-lock"></i> Mật khẩu đăng nhập</label>
            <input type="password" id="admin-create-password" class="input-field"
              placeholder="Mật khẩu tối thiểu 6 ký tự..." required autocomplete="new-password">
          </div>

          <div class="form-group">
            <label for="admin-create-role"><i class="fa-solid fa-user-shield"></i> Vai trò</label>
            <select id="admin-create-role" class="input-field select-field">
              <option value="user">User (Thành viên thông thường)</option>
              <option value="admin">Admin (Quản trị viên toàn cục)</option>
            </select>
          </div>

          <div class="form-group">
            <label for="admin-create-status"><i class="fa-solid fa-circle-check"></i> Trạng thái</label>
            <select id="admin-create-status" class="input-field select-field">
              <option value="active">Active (Hoạt động bình thường)</option>
              <option value="suspended">Suspended (Tạm dừng/Khóa)</option>
            </select>
          </div>

          <div class="form-group">
            <label for="admin-create-limit"><i class="fa-solid fa-gauge"></i> Hạn mức Token/Ngày</label>
            <input type="number" id="admin-create-limit" class="input-field" placeholder="Không giới hạn..." min="0">
            <small class="text-secondary mt-1 block">Để trống hoặc nhập 0 để cấu hình sử dụng không giới hạn.</small>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" onclick="closeCreateUserModal()" class="btn btn-secondary">Hủy</button>
          <button type="submit" class="btn btn-primary">Tạo tài khoản</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Admin Change User Password Modal -->
  <div id="change-password-modal" class="modal-overlay" style="display: none;">
    <div class="modal-card animate-zoom">
      <div class="modal-header">
        <h3><i class="fa-solid fa-key text-gradient"></i> Đổi Mật Khẩu Thành Viên</h3>
        <button class="close-modal-btn" onclick="closeChangePasswordModal()">&times;</button>
      </div>
      <form id="change-password-form" onsubmit="handleChangePassword(event)">
        <div class="modal-body">
          <p class="text-secondary mb-4">Nhập mật khẩu mới cho tài khoản <strong id="change-password-username-display"
              class="text-gradient">username</strong> bên dưới.</p>

          <input type="hidden" id="change-password-user-id">

          <div class="form-group">
            <label for="admin-change-password-value"><i class="fa-solid fa-lock"></i> Mật khẩu mới</label>
            <input type="password" id="admin-change-password-value" class="input-field"
              placeholder="Mật khẩu tối thiểu 6 ký tự..." required autocomplete="new-password">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" onclick="closeChangePasswordModal()" class="btn btn-secondary">Hủy</button>
          <button type="submit" class="btn btn-primary">Đặt mật khẩu mới</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Admin Set User Daily Token Limit Modal -->
  <div id="set-limit-modal" class="modal-overlay" style="display: none;">
    <div class="modal-card animate-zoom">
      <div class="modal-header">
        <h3><i class="fa-solid fa-gauge text-gradient"></i> Đổi Hạn Mức Token Hàng Ngày</h3>
        <button class="close-modal-btn" onclick="closeSetLimitModal()">&times;</button>
      </div>
      <form id="set-limit-form" onsubmit="handleSetLimit(event)">
        <div class="modal-body">
          <p class="text-secondary mb-4">Nhập hạn mức Token hàng ngày cho tài khoản <strong
              id="set-limit-username-display" class="text-gradient">username</strong> bên dưới.</p>

          <input type="hidden" id="set-limit-user-id">

          <div class="form-group">
            <label for="admin-set-limit-value"><i class="fa-solid fa-bolt"></i> Hạn mức Token/Ngày</label>
            <input type="number" id="admin-set-limit-value" class="input-field" placeholder="Không giới hạn..." min="0">
            <small class="text-secondary mt-1 block">Để trống hoặc nhập 0 để cấu hình sử dụng không giới hạn.</small>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" onclick="closeSetLimitModal()" class="btn btn-secondary">Hủy</button>
          <button type="submit" class="btn btn-primary">Lưu hạn mức</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Admin Log Detail Modal -->
  <div id="log-detail-modal" class="modal-overlay" style="display: none;">
    <div class="modal-card animate-zoom max-w-xl">
      <div class="modal-header">
        <h3><i class="fa-solid fa-file-invoice text-gradient"></i> Chi Tiết Giao Dịch API</h3>
        <button class="close-modal-btn" onclick="closeLogDetailModal()">&times;</button>
      </div>
      <div class="modal-body">
        <div class="stats-grid grid-3 mb-4"
          style="grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 20px;">
          <div class="stats-card py-2" style="padding: 10px; text-align: center;">
            <div class="stats-label" style="font-size: 10px; text-transform: uppercase;">Model</div>
            <div class="stats-num text-gradient" style="font-size: 13px; font-weight: bold; margin-top: 5px;"
              id="log-detail-model">-</div>
          </div>
          <div class="stats-card py-2" style="padding: 10px; text-align: center;">
            <div class="stats-label" style="font-size: 10px; text-transform: uppercase;">Tokens</div>
            <div class="stats-num text-gradient" style="font-size: 13px; font-weight: bold; margin-top: 5px;"
              id="log-detail-tokens">0</div>
          </div>
          <div class="stats-card py-2" style="padding: 10px; text-align: center;">
            <div class="stats-label" style="font-size: 10px; text-transform: uppercase;">Thời gian</div>
            <div style="font-size: 10px; margin-top: 5px;" id="log-detail-time">-</div>
          </div>
        </div>

        <div class="form-group">
          <label class="text-secondary" style="font-size: 12px; font-weight: bold;"><i class="fa-solid fa-link"></i>
            Endpoint & Backend API URL</label>
          <div class="code-box-wrapper mt-1">
            <pre class="code-block"
              style="font-size: 11px; padding: 10px; border-radius: 6px; max-height: 80px; overflow-y: auto;"><code id="log-detail-urls" class="text-gradient" style="font-weight: 500;">GET /api/chat...</code></pre>
          </div>
        </div>

        <div class="form-group mt-3" style="margin-top: 15px;">
          <label class="text-secondary" style="font-size: 12px; font-weight: bold;"><i
              class="fa-solid fa-comment-dots"></i> Prompt Đầu Vào (Input Messages)</label>
          <div class="code-box-wrapper mt-1">
            <pre class="code-block"
              style="max-height: 150px; overflow-y: auto; font-size: 11px; padding: 10px; border-radius: 6px; background-color: #1E150F; color: #F5E6D3;"><code id="log-detail-prompt">...</code></pre>
          </div>
        </div>

        <div class="form-group mt-3" style="margin-top: 15px;">
          <label class="text-secondary" style="font-size: 12px; font-weight: bold;"><i
              class="fa-solid fa-reply-all"></i> Dữ Liệu Phản Hồi Đầu Ra (Output Response)</label>
          <div class="code-box-wrapper mt-1">
            <pre class="code-block"
              style="max-height: 150px; overflow-y: auto; white-space: pre-wrap; font-size: 11px; padding: 10px; border-radius: 6px; background-color: #1E150F; color: #F5E6D3;"><code id="log-detail-response">...</code></pre>
          </div>
        </div>
      </div>
      <div class="modal-footer" style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px;">
        <button type="button" onclick="closeLogDetailModal()" class="btn btn-secondary">Đóng</button>
        <button type="button" id="btn-delete-log-in-modal" class="btn btn-danger"><i class="fa-solid fa-trash-can"></i>
          Xóa Log Này</button>
      </div>
    </div>
  </div>

  <!-- Fullscreen Loading Overlay -->
  <div id="global-loading-overlay" class="modal-overlay" style="display: none; z-index: 9999; background: rgba(0,0,0,0.6); backdrop-filter: blur(5px);">
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 15px; background: hsl(var(--bg-card)); padding: 30px; border-radius: 16px; border: 1px solid hsl(var(--border)); box-shadow: 0 10px 30px rgba(0,0,0,0.25);">
      <i class="fa-solid fa-circle-notch fa-spin text-gradient" style="font-size: 3rem; color: hsl(var(--primary));"></i>
      <span id="global-loading-text" style="font-weight: 600; color: hsl(var(--text-primary)); font-size: 1rem;">Đang xử lý, vui lòng đợi...</span>
    </div>
  </div>

  <!-- External UI Animation Libraries -->
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>

  <!-- Google Identity Services (GIS) for Google Sign-In -->
  <script src="https://accounts.google.com/gsi/client" async defer></script>

  <!-- Core Front-End JavaScript Application -->
  <script src="/js/app.js?v=1.3"></script>
</body>

</html>